        r.total_return_amount,
        0
    ) AS net_sales

FROM `ecommerce_analytics_platform`.`dev_intermediate`.`int_orders_details` o

LEFT JOIN `ecommerce_analytics_platform`.`dev_analytics`.`dim_customer` c
ON o.customer_id = c.customer_id

LEFT JOIN `ecommerce_analytics_platform`.`dev_analytics`.`dim_product` p
ON o.product_id = p.product_id

LEFT JOIN `ecommerce_analytics_platform`.`dev_intermediate`.`int_returns_summary` r
ON o.order_id = r.order_id
  
