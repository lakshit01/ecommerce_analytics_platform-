LEFT JOIN `ecommerce_analytics_platform`.`dev_analytics`.`dim_product` p
ON o.product_id = p.product_id

LEFT JOIN `ecommerce_analytics_platform`.`dev_intermediate`.`int_returns_summary` r
ON o.order_id = r.order_id



WHERE o.order_date >= (
    SELECT date_sub(max(order_date), 7)
    FROM `ecommerce_analytics_platform`.`dev_analytics`.`fact_sales`
)
  
