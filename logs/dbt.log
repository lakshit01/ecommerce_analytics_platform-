    using delta
  
      
      
      
      
      
      
      
      
      as
      SELECT

    o.order_id,
    c.customer_sk,
    p.product_sk,

    o.customer_id,
    o.product_id,

    o.order_date,
    o.quantity,
    o.amount,

    COALESCE(
        r.total_return_amount,
        0
    ) AS return_amount,

